# {{ ansible_managed }}

[global]
   workgroup = {{ samba_workgroup }}
   server string = {{ samba_server_string }}
   netbios name = {{ ansible_hostname }}

   security = user
   map to guest = bad user
   guest account = nobody

   server min protocol = {{ samba_min_protocol }}

   load printers = no
   printing = bsd
   printcap name = /dev/null
   disable spoolss = yes

   log file = /var/log/samba/log.%m
   max log size = 1000
   dns proxy = no

{% for share in samba_shares %}
[{{ share.name }}]
   comment = {{ share.comment }}
   path = {{ share.path }}
   browseable = yes
   guest ok = yes
   guest only = yes
   read only = no
   writable = yes
   force user = {{ samba_force_user_name }}
   force group = {{ samba_force_group_name }}
   create mask = {{ samba_create_mask }}
   directory mask = {{ samba_directory_mask }}

{% endfor %}
